---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'dr. Kresna Sucandra — Physician · Builder · Researcher',
  description = 'Anesthesiologist, intensivist, and systems engineer based in Denpasar, Bali.',
} = Astro.props;

const TRACE_PATH = 'M0 16 H54 L62 3 L70 29 L78 16 H150 L158 8 L166 24 L174 16 H250 L256 10 L262 22 L268 16 H400';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/?$/, '/')}favicon.svg`} />
</head>
<body>

<nav>
  <a href="#hero" class="nav-mark">dr. <i>Kresna</i> Sucandra</a>
  <ul class="nav-links">
    <li><a href="#domains">Domains</a></li>
    <li><a href="#ventures">Ventures</a></li>
    <li><a href="#projects">Open Source</a></li>
    <li><a href="#about">About</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
</nav>

<div class="telemetry" aria-hidden="true">
  <svg class="telemetry-track" viewBox="0 0 400 32" preserveAspectRatio="none"><path d={TRACE_PATH} /></svg>
  <svg class="telemetry-track" viewBox="0 0 400 32" preserveAspectRatio="none"><path d={TRACE_PATH} /></svg>
</div>

<slot />

<footer>
  <span class="fc">© 2026 dr. Kresna Sucandra, SpAn-TI, Subsp.T.I.(K) · All rights reserved.</span>
  <span class="ft">From Bali, world.</span>
</footer>

</body>
</html>

<style is:global>
  @import '../styles/global.css';

  /* ─── NAV ─── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 200;
    display: flex; justify-content: space-between; align-items: center;
    padding: 0 3.5rem;
    height: 60px;
    background: rgba(10,13,12,0.82);
    backdrop-filter: blur(18px);
    border-bottom: 1px solid var(--line);
  }
  .nav-mark {
    font-family: 'Fragment Mono', monospace;
    font-size: 0.92rem; font-weight: 400;
    color: var(--paper); letter-spacing: 0.01em; text-decoration: none;
  }
  .nav-mark i { font-style: italic; color: var(--trace); }
  .nav-links { list-style: none; display: flex; gap: 2.25rem; }
  .nav-links a {
    font-family: 'Fragment Mono', monospace;
    font-size: var(--fs-ui); font-weight: 400;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--dim); text-decoration: none; transition: color 0.2s;
  }
  .nav-links a:hover, .nav-links a.on { color: var(--trace); }

  /* ─── TELEMETRY: signature live trace, sweeping under the nav ─── */
  .telemetry {
    position: fixed; top: 60px; left: 0; right: 0; z-index: 150;
    height: 17px; overflow: hidden; display: flex;
    background: rgba(10,13,12,0.82);
    border-bottom: 1px solid var(--line);
    opacity: 0.32; pointer-events: none;
    animation: sweep 13s linear infinite;
  }
  .telemetry-track { flex-shrink: 0; width: 400px; height: 100%; display: block; }
  .telemetry-track path { fill: none; stroke: var(--trace); stroke-width: 1.1; }
  @keyframes sweep { from { transform: translateX(0); } to { transform: translateX(-400px); } }
  @media (prefers-reduced-motion: reduce) { .telemetry { animation: none; } }

  /* ─── FOOTER ─── */
  footer {
    background: var(--panel);
    border-top: 1px solid var(--line);
    padding: 1.4rem 3.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .fc { font-family: 'Fragment Mono', monospace; font-size: var(--fs-micro); color: var(--dim2); letter-spacing: 0.02em; }
  .ft {
    font-family: 'Literata', serif;
    font-size: var(--fs-ui); font-style: italic;
    color: var(--dim2);
  }

  @media (max-width: 1024px) {
    nav { padding: 0 1.75rem; }
    .nav-links { display: none; }
    footer { padding: 1.4rem 1.75rem; }
  }
  @media (max-width: 600px) {
    footer { flex-direction: column; gap: 0.4rem; text-align: center; }
    .telemetry { display: none; }
  }
</style>

<script>
  // Scroll reveal
  const obs = new IntersectionObserver(
    (es) => es.forEach((e) => { if (e.isIntersecting) e.target.classList.add('on'); }),
    { threshold: 0.06, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.rv').forEach((el) => obs.observe(el));

  // Active nav link
  const secs = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('.nav-links a');
  window.addEventListener('scroll', () => {
    let cur = '';
    secs.forEach((s) => { if (window.scrollY >= (s as HTMLElement).offsetTop - 200) cur = s.id; });
    navLinks.forEach((a) => a.classList.toggle('on', a.getAttribute('href') === `#${cur}`));
  }, { passive: true });
</script>
