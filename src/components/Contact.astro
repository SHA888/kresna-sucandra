<section id="contact">
  <div class="contact-bg" aria-hidden="true">
    <svg viewBox="0 0 1200 500" preserveAspectRatio="xMidYMid slice">
      <path d="M0 250 H420 L440 130 L462 370 L484 250 H620" fill="none" stroke="rgba(75,190,138,0.24)" stroke-width="1.3" />
      <path d="M600 250 Q 700 180, 800 250 T 1000 250 T 1200 250" fill="none" stroke="rgba(74,160,196,0.22)" stroke-width="1.3" />
      <path d="M580 250 Q 700 330, 800 250 T 1000 250 T 1200 250" fill="none" stroke="rgba(201,98,118,0.2)" stroke-width="1.3" />
      <circle cx="600" cy="250" r="4" fill="rgba(237,231,218,0.6)" />
    </svg>
  </div>
  <div class="contact-wrap">
    <div class="c-left">
      <div class="label">Contact</div>
      <h2 class="c-hl">Let's work on<br /><em>something real</em>.</h2>
      <p class="c-sub">Clinical AI collaboration, quantum research, open source, or the intersection of Balinese wisdom and frontier technology — reach out.</p>
      <a href="mailto:kresnasucandra@gmail.com" class="btn-primary">Contact</a>
    </div>

    <div class="c-right">
      <div class="social-label">Elsewhere</div>
      <div class="social-links">
        <a href="https://www.linkedin.com/in/kresna-sucandra/" target="_blank" rel="noopener" class="social-link">
          <span class="sl-name">LinkedIn</span>
          <span class="sl-handle">dr. Kresna Sucandra</span>
        </a>
        <a href="https://github.com/SHA888" target="_blank" rel="noopener" class="social-link">
          <span class="sl-name">GitHub</span>
          <span class="sl-handle">SHA888</span>
        </a>
        <a href="https://x.com/ks_sha888" target="_blank" rel="noopener" class="social-link">
          <span class="sl-name">Twitter / X</span>
          <span class="sl-handle">@ks_sha888</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  #contact {
    background: var(--panel);
    border-top: 1px solid var(--line);
    position: relative;
    overflow: hidden;
  }
  .contact-bg { position: absolute; inset: 0; pointer-events: none; opacity: 0.5; }
  .contact-bg svg { width: 100%; height: 100%; }

  .contact-wrap {
    max-width: 1200px; margin: 0 auto; padding: 6rem 3.5rem;
    display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: center;
    position: relative; z-index: 1;
  }

  .c-hl {
    font-family: 'Fragment Mono', monospace;
    font-size: var(--fs-h1);
    font-weight: 400; color: var(--paper); line-height: 1.25; margin-bottom: 1.1rem;
  }
  .c-hl em { font-style: italic; color: var(--alert); }
  .c-sub { font-family: 'Literata', serif; font-size: var(--fs-lead); color: var(--dim); line-height: 1.85; margin-bottom: 2rem; }

  .social-label {
    font-family: 'Fragment Mono', monospace;
    font-size: var(--fs-micro); font-weight: 400;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--dim2);
    margin-bottom: 1.25rem;
  }

  .social-links { display: flex; flex-direction: column; gap: 0; }
  .social-link {
    display: flex; justify-content: space-between; align-items: center;
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--line);
    text-decoration: none;
    transition: all 0.2s;
  }
  .social-link:last-child { border-bottom: none; }
  .social-link:hover { padding-left: 0.5rem; }

  .sl-name {
    font-size: var(--fs-title);
    font-family: 'Fragment Mono', monospace;
    font-weight: 400; color: var(--paper);
  }
  .sl-handle {
    font-family: 'Literata', serif;
    font-size: var(--fs-ui); font-style: italic; color: var(--dim2);
    transition: color 0.2s;
  }
  .social-link:hover .sl-name { color: var(--trace); }
  .social-link:hover .sl-handle { color: var(--dim); }

  @media (max-width: 1024px) {
    .contact-wrap { grid-template-columns: 1fr; gap: 3rem; padding: 4rem 1.75rem; }
  }
</style>
