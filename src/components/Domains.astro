---
const domains = [
  {
    icon: '🫁',
    title: 'Critical Care Medicine',
    desc: "In intensive care since 2012, across RSUP Ngoerah, Siloam Hospital Denpasar, and Bali International Hospital. I head RSUP Ngoerah's fellowship program and still spend most of my time teaching.",
    tags: ['ICU', 'Anesthesiology', 'Sepsis', 'EBM'],
  },
  {
    icon: '🧬',
    title: 'Clinical AI & ML',
    desc: "Leading a PROSPERO-registered systematic review (CRD420251164609) on biomarker-enhanced ML for early sepsis detection — PROBAST done, manuscript in its final stage. I also head Data Science & AI at Udayana's Anesthesiology and Intensive Care Department.",
    tags: ['Biomarkers', 'MIMIC-IV', 'Bayesian', 'PROSPERO'],
  },
  {
    icon: '⚛️',
    title: 'Quantum-AI',
    desc: "The Reciprocal Acceleration Framework (RAF) — my attempt at a systematic account of how quantum computing and machine learning pull each other forward. Early-stage, open research.",
    tags: ['RAF', 'VQE', 'NISQ', 'Qiskit'],
  },
  {
    icon: '🦀',
    title: 'Systems Engineering',
    desc: 'Mostly Rust, close to the metal — several crates on crates.io spanning swarm intelligence, healthcare tooling, and data infrastructure. Before that, blockchain engineering: co-founder at InvArch and PillarHub Network, developer at Gemini Teknologi Indonesia.',
    tags: ['Rust', 'LLVM', 'Blockchain', 'FHIR/HL7'],
  },
  {
    icon: '🌿',
    title: 'Interest in Biodiversity & Pharma',
    desc: "An ongoing interest, not yet a project: Indonesia's biodiversity, traditional Jamu medicine, and what ancestral plant knowledge still has to teach modern pharmacology.",
    tags: ['Jamu', 'Temulawak', 'Fermentation', 'Ethnobotany'],
  },
  {
    icon: '🎓',
    title: 'Medical Lecturer & Doctoral Student',
    desc: "I teach anesthesiology and critical care at Udayana University, mentor residents, and supervise theses — while also a doctoral (S3) student myself, researching ML in critical care.",
    tags: ['S3 Doctoral', 'Udayana', 'Lecturer', 'Research'],
  },
];
---
<section id="domains">
  <div class="sw">
    <div class="label">Expertise</div>
    <h2 class="display">Six disciplines.<br /><em>One continuous thread.</em></h2>
    <div class="domain-layout rv">
      {domains.map((d) => (
        <div class="domain-cell">
          <div class="dc-top">
            <span class="dc-icon">{d.icon}</span>
          </div>
          <div class="dc-title">{d.title}</div>
          <div class="dc-desc">{d.desc}</div>
          <div class="dc-tags">
            {d.tags.map((t) => <span class="tag">{t}</span>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #domains { background: var(--panel); border-top: 1px solid var(--line); }

  .domain-layout {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0;
    border: 1px solid var(--line);
    border-radius: 0;
    overflow: hidden;
  }
  .domain-cell {
    padding: 2rem 1.75rem;
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    background: var(--void);
    transition: background 0.25s;
  }
  .domain-cell:nth-child(3n)   { border-right: none; }
  .domain-cell:nth-child(n+4)  { border-bottom: none; }
  .domain-cell:hover { background: var(--panel2); }

  .dc-top { margin-bottom: 1rem; }
  .dc-icon  { font-size: 1.2rem; filter: grayscale(1) contrast(1.15) brightness(1.3); opacity: 0.75; }
  .dc-title {
    font-family: 'Fragment Mono', monospace;
    font-size: var(--fs-title); font-weight: 400;
    color: var(--paper); margin-bottom: 0.6rem; line-height: 1.3;
  }
  .dc-desc  { font-size: var(--fs-body); color: var(--dim); line-height: 1.8; font-family: 'Literata', serif; }
  .dc-tags  { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 1.1rem; }

  @media (max-width: 1024px) {
    .domain-layout { grid-template-columns: 1fr 1fr; }
    .domain-cell:nth-child(3n)  { border-right: 1px solid var(--line); }
    .domain-cell:nth-child(2n)  { border-right: none; }
    .domain-cell:nth-child(n+4) { border-bottom: 1px solid var(--line); }
    .domain-cell:nth-child(n+5) { border-bottom: none; }
  }
  @media (max-width: 600px) {
    .domain-layout { grid-template-columns: 1fr; }
    .domain-cell { border-right: none !important; border-bottom: 1px solid var(--line) !important; }
    .domain-cell:last-child { border-bottom: none !important; }
  }
</style>
