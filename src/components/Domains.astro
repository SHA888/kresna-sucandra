---
const domains = [
  {
    icon: '🫁',
    title: 'Critical Care Medicine',
    desc: "In intensive care since 2012 — as an anesthesiologist and intensivist at RSUP Ngoerah, where I also head the Intensive Care Fellowship Program; as Head of Critical Care at Siloam Hospital Denpasar; and, more recently, at Bali International Hospital. A lot of that time goes to teaching — residents learn faster when someone's actually in the room with them.",
    tags: ['ICU', 'Anesthesiology', 'Sepsis', 'EBM'],
  },
  {
    icon: '🧬',
    title: 'Clinical AI & ML',
    desc: "Sepsis is hardest to catch in the hours before anyone's watching closely enough. I'm leading a PROSPERO-registered systematic review (CRD420251164609) on whether biomarker-enhanced machine learning can catch it earlier in pre-ICU settings — PROBAST bias analysis is done, manuscript in its final stage. I also head Data Science & AI for the Anesthesiology and Intensive Care Department at Udayana University.",
    tags: ['Biomarkers', 'MIMIC-IV', 'Bayesian', 'PROSPERO'],
  },
  {
    icon: '⚛️',
    title: 'Quantum-AI',
    desc: "A side obsession that turned into real research: the Reciprocal Acceleration Framework (RAF), my attempt at a systematic account of how quantum computing and machine learning are pulling each other forward. Still early-stage, still open — one of the more fun problems I've found.",
    tags: ['RAF', 'VQE', 'NISQ', 'Qiskit'],
  },
  {
    icon: '🦀',
    title: 'Systems Engineering',
    desc: 'Most of what I build is in Rust, close to the metal. Several crates live on crates.io now — swarm intelligence, healthcare language tooling, data warehouse infrastructure. Before that, I was a blockchain engineer in Rust — co-founder and Substrate runtime developer at InvArch, co-founder at PillarHub Network, and a blockchain developer at Gemini Teknologi Indonesia.',
    tags: ['Rust', 'LLVM', 'Blockchain', 'FHIR/HL7'],
  },
  {
    icon: '🌿',
    title: 'Interest in Biodiversity & Pharma',
    desc: "An ongoing interest, not yet a project: Indonesia's biodiversity, traditional Jamu medicine, and what fermentation science and modern pharmacology can learn from each other. I think a lot about what ancestral plant knowledge still has to teach contemporary medicine.",
    tags: ['Jamu', 'Temulawak', 'Fermentation', 'Ethnobotany'],
  },
  {
    icon: '🎓',
    title: 'Medical Lecturer & Doctoral Student',
    desc: "I teach anesthesiology and critical care at Udayana University, mentor residents, and supervise thesis work. Right now I'm also on the other side of the desk — a doctoral (S3) student, researching how machine learning applies to critical care.",
    tags: ['S3 Doctoral', 'Udayana', 'Lecturer', 'Research'],
  },
];
---
<section id="domains">
  <div class="sw">
    <div class="label">Expertise</div>
    <h2 class="display">Six disciplines.<br /><em>One continuous thread.</em></h2>
    <div class="domain-layout rv">
      {domains.map((d) => (
        <div class="domain-cell">
          <div class="dc-top">
            <span class="dc-icon">{d.icon}</span>
          </div>
          <div class="dc-title">{d.title}</div>
          <div class="dc-desc">{d.desc}</div>
          <div class="dc-tags">
            {d.tags.map((t) => <span class="tag">{t}</span>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #domains { background: var(--panel); border-top: 1px solid var(--line); }

  .domain-layout {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0;
    border: 1px solid var(--line);
    border-radius: 0;
    overflow: hidden;
  }
  .domain-cell {
    padding: 2rem 1.75rem;
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    background: var(--void);
    transition: background 0.25s;
  }
  .domain-cell:nth-child(3n)   { border-right: none; }
  .domain-cell:nth-child(n+4)  { border-bottom: none; }
  .domain-cell:hover { background: var(--panel2); }

  .dc-top { margin-bottom: 1rem; }
  .dc-icon  { font-size: 1.2rem; filter: grayscale(1) contrast(1.15) brightness(1.3); opacity: 0.75; }
  .dc-title {
    font-family: 'Fragment Mono', monospace;
    font-size: var(--fs-title); font-weight: 400;
    color: var(--paper); margin-bottom: 0.6rem; line-height: 1.3;
  }
  .dc-desc  { font-size: var(--fs-body); color: var(--dim); line-height: 1.8; font-family: 'Literata', serif; }
  .dc-tags  { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 1.1rem; }

  @media (max-width: 1024px) {
    .domain-layout { grid-template-columns: 1fr 1fr; }
    .domain-cell:nth-child(3n)  { border-right: 1px solid var(--line); }
    .domain-cell:nth-child(2n)  { border-right: none; }
    .domain-cell:nth-child(n+4) { border-bottom: 1px solid var(--line); }
    .domain-cell:nth-child(n+5) { border-bottom: none; }
  }
  @media (max-width: 600px) {
    .domain-layout { grid-template-columns: 1fr; }
    .domain-cell { border-right: none !important; border-bottom: 1px solid var(--line) !important; }
    .domain-cell:last-child { border-bottom: none !important; }
  }
</style>
