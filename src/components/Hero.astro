---
---
<section id="hero">
  <div class="hero-bg">
    <svg viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
      <!-- oscilloscope grid -->
      <g stroke="rgba(237,231,218,0.05)" stroke-width="1">
        <line x1="0" y1="150" x2="1440" y2="150" /><line x1="0" y1="300" x2="1440" y2="300" />
        <line x1="0" y1="450" x2="1440" y2="450" /><line x1="0" y1="600" x2="1440" y2="600" />
        <line x1="0" y1="750" x2="1440" y2="750" />
        <line x1="240" y1="0" x2="240" y2="900" /><line x1="480" y1="0" x2="480" y2="900" />
        <line x1="720" y1="0" x2="720" y2="900" /><line x1="960" y1="0" x2="960" y2="900" />
        <line x1="1200" y1="0" x2="1200" y2="900" />
      </g>
      <!-- ECG trace, right field -->
      <path d="M760 260 H960 L978 190 L998 340 L1018 260 H1160 L1174 220 L1188 300 L1202 260 H1440"
        fill="none" stroke="rgba(75,190,138,0.32)" stroke-width="1.5" />
      <!-- quantum interference wave, lower field -->
      <path d="M700 700 Q 790 640, 880 700 T 1060 700 T 1240 700 T 1420 700"
        fill="none" stroke="rgba(74,160,196,0.26)" stroke-width="1.2" />
      <path d="M700 730 Q 790 790, 880 730 T 1060 730 T 1240 730 T 1420 730"
        fill="none" stroke="rgba(74,160,196,0.14)" stroke-width="1.2" />
    </svg>
  </div>

  <div class="hero-eyebrow">Denpasar, Bali · Indonesia</div>

  <h1 class="hero-hl">
    dr. <em>Kresna</em><br />Sucandra
  </h1>

  <div class="hero-row">
    <p class="hero-cred">
      SpAn-TI, Subsp.T.I.(K) &mdash; Anesthesiologist &amp; Intensivist, in the ICU since 2012.<br /><br />
      RSUP Ngoerah, Siloam Hospital Denpasar, Bali International Hospital &mdash; and a PhD student, Udayana University.
    </p>
    <div class="hero-right-col">
      <div class="hero-pills">
        <span class="hpill">Sepsis &amp; Biomarkers</span>
        <span class="hpill">Machine Learning</span>
        <span class="hpill">Rust &amp; Systems</span>
        <span class="hpill">Quantum-AI</span>
        <span class="hpill">Balinese Culture</span>
        <span class="hpill">Biodiversity Pharma</span>
        <span class="hpill">Clinical Research</span>
        <span class="hpill">Web3 · Substrate</span>
      </div>
      <div class="hero-btns">
        <a href="#ventures" class="btn-primary">Explore Work</a>
        <a href="#contact" class="btn-outline">Get in Touch</a>
      </div>
    </div>
  </div>

  <div class="scroll-hint">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  #hero {
    min-height: 100vh;
    background: var(--void);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0 3.5rem 5rem;
    position: relative;
    overflow: hidden;
  }
  .hero-bg { position: absolute; inset: 0; pointer-events: none; }
  .hero-bg svg { width: 100%; height: 100%; }

  .hero-eyebrow {
    font-family: 'Fragment Mono', monospace;
    font-size: var(--fs-ui); font-weight: 400;
    letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--trace); margin-bottom: 1.25rem;
    display: flex; align-items: center; gap: 0.75rem;
    position: relative; z-index: 2;
  }
  .hero-eyebrow::before { content: ''; width: 28px; height: 1.5px; background: var(--trace); }

  .hero-hl {
    font-family: 'Fragment Mono', monospace;
    font-size: var(--fs-hero);
    font-weight: 400; line-height: 0.98;
    color: var(--paper); letter-spacing: -0.03em;
    margin-bottom: 1.75rem;
    position: relative; z-index: 2;
  }
  .hero-hl em { font-style: italic; color: var(--trace); }

  .hero-row {
    display: flex; align-items: flex-end;
    justify-content: space-between; gap: 3rem;
    position: relative; z-index: 2;
  }
  .hero-cred {
    font-family: 'Literata', serif;
    font-size: var(--fs-lead); font-style: italic;
    color: var(--dim); line-height: 1.6;
    border-left: 2px solid var(--pulse);
    padding-left: 1rem; max-width: 400px;
  }
  .hero-right-col {
    display: flex; flex-direction: column;
    align-items: flex-end; gap: 1.25rem;
  }
  .hero-pills {
    display: flex; flex-wrap: wrap;
    gap: 0.45rem; justify-content: flex-end; max-width: 420px;
  }
  .hpill {
    font-family: 'Fragment Mono', monospace;
    font-size: var(--fs-ui); font-weight: 400;
    padding: 0.32rem 0.85rem; border-radius: 0;
    background: var(--panel);
    border: 1px solid var(--line);
    color: var(--dim); transition: all 0.2s;
  }
  .hpill:hover { background: var(--trace); color: var(--void); border-color: var(--trace); }
  .hero-btns { display: flex; gap: 0.75rem; }

  .scroll-hint {
    position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 0.4rem;
    z-index: 2; opacity: 0.5;
  }
  .scroll-hint span { font-family: 'Fragment Mono', monospace; font-size: var(--fs-micro); letter-spacing: 0.15em; text-transform: uppercase; color: var(--dim); }
  .scroll-line { width: 1px; height: 32px; background: var(--trace); animation: scrollpulse 2s ease-in-out infinite; }
  @keyframes scrollpulse { 0%,100%{ opacity: 0.3; } 50%{ opacity: 1; } }

  @media (max-width: 1024px) {
    #hero { padding: 0 1.75rem 4rem; }
    .hero-row { flex-direction: column; align-items: flex-start; gap: 2rem; }
    .hero-right-col { align-items: flex-start; }
    .hero-pills { justify-content: flex-start; }
  }
  @media (max-width: 600px) {
    .hero-hl { font-size: clamp(2.6rem, 11vw, 4rem); }
    .scroll-hint { display: none; }
  }
</style>
