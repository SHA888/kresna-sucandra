---
---
<section id="hero">
  <div class="hero-bg">
    <svg viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
      <circle cx="1200" cy="180" r="320" fill="none" stroke="rgba(28,22,14,0.045)" stroke-width="1"/>
      <circle cx="1200" cy="180" r="240" fill="none" stroke="rgba(28,22,14,0.04)"  stroke-width="1"/>
      <circle cx="1200" cy="180" r="160" fill="none" stroke="rgba(28,22,14,0.035)" stroke-width="1"/>
      <circle cx="1200" cy="180" r="80"  fill="none" stroke="rgba(28,22,14,0.03)"  stroke-width="1"/>
      <ellipse cx="1200" cy="180" rx="60" ry="120" fill="none" stroke="rgba(155,61,26,0.06)" stroke-width="1"/>
      <ellipse cx="1200" cy="180" rx="60" ry="120" fill="none" stroke="rgba(155,61,26,0.06)" stroke-width="1" transform="rotate(45 1200 180)"/>
      <ellipse cx="1200" cy="180" rx="60" ry="120" fill="none" stroke="rgba(155,61,26,0.06)" stroke-width="1" transform="rotate(90 1200 180)"/>
      <ellipse cx="1200" cy="180" rx="60" ry="120" fill="none" stroke="rgba(155,61,26,0.06)" stroke-width="1" transform="rotate(135 1200 180)"/>
      <line x1="180" y1="0"   x2="180" y2="900" stroke="rgba(28,22,14,0.04)"  stroke-width="1"/>
      <line x1="200" y1="0"   x2="200" y2="900" stroke="rgba(28,22,14,0.025)" stroke-width="0.5"/>
      <line x1="100" y1="820" x2="700" y2="820" stroke="rgba(155,61,26,0.1)"  stroke-width="1"/>
    </svg>
  </div>

  <div class="hero-eyebrow">Denpasar, Bali · Indonesia</div>

  <h1 class="hero-hl">
    dr. <em>Kresna</em><br />Sucandra
  </h1>

  <div class="hero-row">
    <p class="hero-cred">
      SpAn-TI, Subsp.T.I.(K) &mdash; Anesthesiologist &amp;<br />
      Intensive Therapy Consultant &middot; 13 years ICU practice<br />
      CTO &middot; Postgraduate Researcher, Udayana University
    </p>
    <div class="hero-right-col">
      <div class="hero-pills">
        <span class="hpill">Sepsis &amp; Biomarkers</span>
        <span class="hpill">Machine Learning</span>
        <span class="hpill">Rust &amp; Systems</span>
        <span class="hpill">Quantum-AI</span>
        <span class="hpill">Balinese Culture</span>
        <span class="hpill">Biodiversity Pharma</span>
        <span class="hpill">Clinical Research</span>
        <span class="hpill">Web3 · Substrate</span>
      </div>
      <div class="hero-btns">
        <a href="#ventures" class="btn-rust">Explore Work</a>
        <a href="#contact" class="btn-outline">Get in Touch</a>
      </div>
    </div>
  </div>

  <div class="scroll-hint">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  #hero {
    min-height: 100vh;
    background: var(--sand);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0 3.5rem 5rem;
    position: relative;
    overflow: hidden;
  }
  .hero-bg { position: absolute; inset: 0; pointer-events: none; }
  .hero-bg svg { width: 100%; height: 100%; }

  .hero-eyebrow {
    font-size: 0.68rem; font-weight: 600;
    letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--rust); margin-bottom: 1.25rem;
    display: flex; align-items: center; gap: 0.75rem;
    position: relative; z-index: 2;
  }
  .hero-eyebrow::before { content: ''; width: 28px; height: 1.5px; background: var(--rust); }

  .hero-hl {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(4rem, 8vw, 9rem);
    font-weight: 300; line-height: 0.92;
    color: var(--ink); letter-spacing: -0.02em;
    margin-bottom: 1.75rem;
    position: relative; z-index: 2;
  }
  .hero-hl em { font-style: italic; color: var(--rust2); }

  .hero-row {
    display: flex; align-items: flex-end;
    justify-content: space-between; gap: 3rem;
    position: relative; z-index: 2;
  }
  .hero-cred {
    font-family: 'Crimson Pro', serif;
    font-size: 1.05rem; font-style: italic;
    color: var(--ink3); line-height: 1.6;
    border-left: 2px solid var(--rust3);
    padding-left: 1rem; max-width: 400px;
  }
  .hero-right-col {
    display: flex; flex-direction: column;
    align-items: flex-end; gap: 1.25rem;
  }
  .hero-pills {
    display: flex; flex-wrap: wrap;
    gap: 0.45rem; justify-content: flex-end; max-width: 420px;
  }
  .hpill {
    font-size: 0.65rem; font-weight: 500;
    padding: 0.3rem 0.85rem; border-radius: 2px;
    background: rgba(28,22,14,0.06);
    border: 1px solid rgba(28,22,14,0.1);
    color: var(--ink2); transition: all 0.2s;
  }
  .hpill:hover { background: var(--rust); color: #fff; border-color: var(--rust); }
  .hero-btns { display: flex; gap: 0.75rem; }

  .scroll-hint {
    position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 0.4rem;
    z-index: 2; opacity: 0.4;
  }
  .scroll-hint span { font-size: 0.62rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--ink3); }
  .scroll-line { width: 1px; height: 32px; background: var(--ink3); animation: scrollpulse 2s ease-in-out infinite; }
  @keyframes scrollpulse { 0%,100%{ opacity: 0.3; } 50%{ opacity: 1; } }

  @media (max-width: 1024px) {
    #hero { padding: 0 1.75rem 4rem; }
    .hero-row { flex-direction: column; align-items: flex-start; gap: 2rem; }
    .hero-right-col { align-items: flex-start; }
    .hero-pills { justify-content: flex-start; }
  }
  @media (max-width: 600px) {
    .hero-hl { font-size: clamp(3rem, 12vw, 4.5rem); }
  }
</style>
